# TT Studio Environment Configuration
#
# This is the single, canonical env file for the whole project. `python run.py`
# creates `.env` from this template at the repo root and fills in the values.
# Edit `.env` (not this template) to change your configuration.

# ─────────────────────────────────────────────────────────────────────────────
# Core application paths (auto-configured by run.py)
# ─────────────────────────────────────────────────────────────────────────────
TT_STUDIO_ROOT=<PATH_TO_ROOT_OF_REPO>
HOST_PERSISTENT_STORAGE_VOLUME=${TT_STUDIO_ROOT}/tt_studio_persistent_volume
INTERNAL_PERSISTENT_STORAGE_VOLUME=/tt_studio_persistent_volume
BACKEND_API_HOSTNAME=tt-studio-backend-api

# ─────────────────────────────────────────────────────────────────────────────
# Inference server artifact (which tt-inference-server build to use)
# Pin a release version for stability, or set a branch for development.
# ─────────────────────────────────────────────────────────────────────────────
# NOTE: pinned to a commit SHA — the Wan2.2-T2V TT_DIT_CACHE_DIR dev-catalog fix lands
# in commit b788278 (tenstorrent/tt-inference-server). The source branch was deleted but
# the SHA is still valid. Re-pin to a release version once that fix ships in a tag.
TT_INFERENCE_ARTIFACT_BRANCH=b788278762b0bcc9332ad453d265050bfa94738d
# TT_INFERENCE_ARTIFACT_VERSION=v0.15.0
# TT_INFERENCE_ARTIFACT_BRANCH=tt-studio/202605

# ─────────────────────────────────────────────────────────────────────────────
# Security credentials (REQUIRED — keep secret in production!)
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=test-secret-456
DJANGO_SECRET_KEY=django-insecure-default
# Hugging Face API token (needed to download gated models)
HF_TOKEN=hf_***

# ─────────────────────────────────────────────────────────────────────────────
# Service API keys
# ─────────────────────────────────────────────────────────────────────────────
# TTS / media inference engine
TTS_API_KEY=your-secret-key
# Docker Control Service (secure Docker operations API)
DOCKER_CONTROL_SERVICE_URL=http://host.docker.internal:8002
DOCKER_CONTROL_JWT_SECRET=change-me-in-production
# Agent web search (optional)
TAVILY_API_KEY=tvly-xxx

# ─────────────────────────────────────────────────────────────────────────────
# LiteLLM gateway
# ─────────────────────────────────────────────────────────────────────────────
# Client-facing key coding agents use to access the gateway
LITELLM_MASTER_KEY=sk-tt-studio-REPLACE-ME
# Internal shared secret the gateway presents to the backend upstream
LITELLM_UPSTREAM_KEY=change-me-internal
# Host port the gateway is published on
LITELLM_PORT=4000

# ─────────────────────────────────────────────────────────────────────────────
# Frontend (VITE_*). Read by the React app via import.meta.env.
# Only VITE_-prefixed variables are exposed to the browser bundle.
# (VITE_BACKEND_URL is fixed in app/frontend/vite.config.ts — do not set it here.)
# ─────────────────────────────────────────────────────────────────────────────
VITE_APP_TITLE="TT Studio"
VITE_APP_LOGO=https://github.com/tenstorrent/tt-metal/raw/main/docs/source/common/images/favicon.png

# Application modes — true or false
VITE_ENABLE_DEPLOYED=false
VITE_ENABLE_RAG_ADMIN=false

# Frontend login (optional)
VITE_ENABLE_LOGIN=false
VITE_LOGIN_USERNAME=
VITE_LOGIN_PASSWORD=

# Chat UI direct-to-model endpoint (optional)
VITE_LLAMA_API_URL=
VITE_LLAMA_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# RAG (required when VITE_ENABLE_RAG_ADMIN=true)
# ─────────────────────────────────────────────────────────────────────────────
RAG_ADMIN_PASSWORD=tt-studio-rag-admin-password

# ─────────────────────────────────────────────────────────────────────────────
# Cloud / external model APIs (only used when VITE_ENABLE_DEPLOYED=true)
# ─────────────────────────────────────────────────────────────────────────────
# Chat UI
CLOUD_CHAT_UI_URL=
CLOUD_CHAT_UI_AUTH_TOKEN=
# Computer vision
CLOUD_YOLOV4_API_URL=
CLOUD_YOLOV4_API_AUTH_TOKEN=
# Speech recognition
CLOUD_SPEECH_RECOGNITION_URL=
CLOUD_SPEECH_RECOGNITION_AUTH_TOKEN=
# Image generation
CLOUD_STABLE_DIFFUSION_URL=
CLOUD_STABLE_DIFFUSION_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Wakeword detection
# ─────────────────────────────────────────────────────────────────────────────
WAKEWORD_MODEL=hey_quiet_box
WAKEWORD_THRESHOLD=0.3
WAKEWORD_DEBUG_SCORES=false

# ─────────────────────────────────────────────────────────────────────────────
# Frontend dev server
# ─────────────────────────────────────────────────────────────────────────────
FRONTEND_HOST=localhost
FRONTEND_PORT=3000
FRONTEND_TIMEOUT=60
